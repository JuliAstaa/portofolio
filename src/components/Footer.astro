---
interface Props {
    name: string;
    available?: boolean;
    availableText?: string;
}

const { name, available = false, availableText = "" } = Astro.props as Props;
const year = new Date().getFullYear();
---

<footer class="py-10 w-full border-t border-line">
    <div class="max-w-content w-full mx-auto px-6 md:px-8">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 font-jetbrains text-xs text-muted">
            <div class="flex items-center gap-4">
                <span class="text-text">{name}</span>
                {available && (
                    <span class="flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-accent block"></span>
                        <span class="uppercase tracking-widest">{availableText}</span>
                    </span>
                )}
            </div>
            <p>© {year} · Dibuat sendiri pakai Astro</p>
        </div>
    </div>
</footer>
