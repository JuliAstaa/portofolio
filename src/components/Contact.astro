---
import type { Contact } from "../types/contact";
import SectionHeader from "./SectionHeader.astro";

interface Props {
    contact: Contact;
}

const { contact } = Astro.props as Props;
---

<section id="contact" data-reveal class="py-24 w-full border-b border-line scroll-mt-20">
    <div class="max-w-content w-full mx-auto px-6 md:px-8">
        <SectionHeader index="04" title="Kontak" />

        <!-- Ajakan -->
        <h2 class="mt-10 max-w-2xl text-4xl md:text-6xl font-grotesk font-medium tracking-tight leading-[1.05]">
            {contact.headline}
        </h2>

        <!-- Email sebagai tombol toska -->
        <a
            href={`mailto:${contact.email}`}
            class="mt-8 inline-block bg-accent text-bg font-jetbrains text-sm rounded-lg px-6 py-3"
        >
            {contact.email}
        </a>

        <!-- Link sosial -->
        <ul class="mt-8 flex flex-wrap gap-6 font-jetbrains text-xs uppercase tracking-widest">
            {contact.socials.map((s) => (
                <li>
                    <a href={s.url} class="text-muted hover:text-accent transition-colors">{s.label}</a>
                </li>
            ))}
        </ul>
    </div>
</section>
