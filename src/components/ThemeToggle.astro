---
// Saklar light/dark. Nilai awal data-theme di-set script inline Layout (anti-flash).
// Track + knob geser; knob pindah kanan saat dark via dark: variant.
---

<button
    id="theme-toggle"
    type="button"
    role="switch"
    aria-label="Ganti tema"
    class="relative inline-flex items-center w-12 h-6 rounded-full border border-line bg-accent/10 transition-colors"
>
    <!-- Knob geser -->
    <span
        class="absolute left-0.5 grid place-items-center w-5 h-5 rounded-full bg-accent text-bg translate-x-0 dark:translate-x-6 transition-transform duration-200"
    >
        <!-- Bulan: light mode -->
        <svg class="w-3 h-3 dark:hidden" viewBox="0 0 24 24" fill="currentColor">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
        <!-- Matahari: dark mode -->
        <svg class="w-3 h-3 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 3v1.5M12 19.5V21M4.2 4.2l1.1 1.1M18.7 18.7l1.1 1.1M3 12h1.5M19.5 12H21M4.2 19.8l1.1-1.1M18.7 5.3l1.1-1.1"></path>
        </svg>
    </span>
</button>

<script>
    const btn = document.getElementById("theme-toggle");
    const sync = () => {
        btn?.setAttribute("aria-checked", String(document.documentElement.dataset.theme === "dark"));
    };
    sync();
    btn?.addEventListener("click", () => {
        const root = document.documentElement;
        const next = root.dataset.theme === "dark" ? "light" : "dark";
        root.dataset.theme = next;
        localStorage.setItem("theme", next);
        sync();
    });
</script>
