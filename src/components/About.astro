---

import type { About } from "../types/about";

interface Props {
    about: About;
}

const { about } = Astro.props as Props;

---

<div id="about" class="py-24 w-full border-b border-accent/20 scroll-mt-20">
    <div class="max-w-content w-full mx-auto px-6 md:px-8">
        <div class="text-sm">
            <p class="font-jetbrains text-accent tracking-widest">02 / TENTANG</p>
        </div>
        <span class="mt-4 block h-px w-full bg-line"></span>
        <div class="content grid md:grid-cols-3 mt-8 gap-8">
            <div class="pfp md:col-span-1">
                <!-- Placeholder foto duotone toska; ganti src ke /images/me.jpg -->
                <div class="aspect-4/5 max-w-56 rounded-lg bg-accent/15 border border-line flex items-center justify-center">
                    <span class="font-jetbrains text-xs uppercase tracking-widest text-muted">Foto</span>
                </div>
            </div>
            <div class="desc md:col-span-2">
                <h2 class="text-3xl md:text-4xl font-grotesk font-medium tracking-tight max-w-lg">{about.title}</h2>
                <p class="text-muted mt-6 max-w-2xl leading-relaxed">{about.body}</p>
                <p class="font-jetbrains text-xs uppercase tracking-widest text-muted mt-8 mb-3">Tools harian</p>
                <div class="flex flex-wrap gap-3">
                    {about.techstack.map((tech) => (
                        <span class="font-jetbrains border border-line text-accent text-xs rounded-full py-1 px-4">{tech}</span>
                    ))}
                </div>
            </div>
        </div>
    </div>
</div>