---
import Topography from "./Topography.astro";
---

<section id="home" class="relative overflow-hidden min-h-screen w-full flex items-center border-b border-accent/20">
    <!-- Garis kontur topografi samar, pojok kanan bawah -->
    <div class="pointer-events-none absolute bottom-0 right-0 w-[70%] md:w-1/2 h-2/3 opacity-[0.13] z-0">
        <Topography />
    </div>
    <div class="relative z-10 max-w-content w-full mx-auto px-6 md:px-8">
        <div class="flex flex-col gap-2">
            <div class="mb-4 flex items-center gap-3 text-muted font-jetbrains uppercase tracking-widest text-xs">
                <span class="h-0.5 w-8 bg-accent block"></span>
                <p>Backend developer · Denpasar, Indonesia</p>
            </div>
            <div>
                <h1 class="text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-grotesk font-medium tracking-tight leading-[0.95]">
                    Juli <br>
                    Astawa<span class="text-accent">.</span>
                </h1>
            </div>
            <div>
                <p class="max-w-xl text-lg md:text-xl text-muted mt-4">Membangun REST API yang efisien, tangguh, dan sangat ramah untuk frontend developer.</p>
            </div>

            <div class="flex flex-wrap gap-4 mt-8">
                <a href="#work" class="bg-accent px-10 py-2 rounded-md text-bg font-jetbrains text-sm">Lihat karya</a>
                <a href="/resume.pdf" class="border border-accent rounded-md py-2 px-8 font-jetbrains text-sm text-accent">Resume</a>
            </div>

            <div class="mt-10 flex items-center gap-2">
                <span class="w-3 h-3 rounded-full block bg-accent"></span>
                <p class="text-muted text-xs font-jetbrains">Tersedia untuk proyek & kerja penuh waktu</p>
            </div>
        </div>
    </div>
</section>