---

import type { Project, Experiment } from "../types/project";
import SectionHeader from "./SectionHeader.astro";

interface Props {
    project: Project;
    experiments: Experiment[];
}

const { project, experiments } = Astro.props as Props;

---

<div id="work" data-reveal class="py-24 w-full border-b border-line scroll-mt-20">
    <div class="max-w-content w-full mx-auto px-6 md:px-8">
        <SectionHeader index="01" title="Karya" note="Featured & eksperimen" />
        <div class="mt-8 main-project grid lg:grid-cols-2 gap-10 items-start">
            <div class="left-content">
                <div class="user-active w-fit flex gap-2 items-center bg-accent/20 py-1 px-4 rounded-full text-xs text-muted font-jetbrains">
                    <span class="block w-2 h-2 bg-accent rounded-full"></span> <p>Live · ada user aktif</p>
                </div>
                <div class="flex flex-col gap-4 mt-4">
                    <h2 class="title text-5xl md:text-6xl font-grotesk font-medium tracking-tight">{project.title}</h2>
                    <p class="text-muted max-w-md">{project.description}</p>
                    <div class="techstack flex flex-wrap gap-2">
                        {project.techstack.map((tech) => (
                            <span class="bg-accent/20 font-jetbrains text-accent text-xs rounded-full py-1 px-3">{tech}</span>
                        ))}
                    </div>
                    <div class="action-button flex flex-wrap gap-4">
                        <a class="block px-5 py-3 bg-accent font-jetbrains text-bg text-sm rounded-lg" href={project.links.live}>Buka produk</a>
                        <a class="border border-accent rounded-lg px-5 py-3 font-jetbrains text-sm text-accent" href={project.links.caseStudy}>Baca case study</a>
                        <a class="border border-accent rounded-lg px-5 py-3 font-jetbrains text-sm text-accent" href={project.links.repo}>Repo</a>
                    </div>
                </div>

            </div>
            <div class="right-content">
                <div class="rounded-2xl border border-line">

                    <!-- Label atas -->
                    <div class="border-b border-line px-6 md:px-8 pt-6 pb-4">
                    <p class="font-jetbrains text-xs uppercase tracking-widest text-muted">Metrik Live</p>
                    </div>

                    <!-- Baris metrik (dari data) -->
                    {project.metrics.map((metric, i) => (
                        <div class:list={["flex items-baseline justify-between gap-3 px-6 md:px-8 py-6", i < project.metrics.length - 1 && "border-b border-line"]}>
                            <p class="text-4xl md:text-5xl lg:text-6xl font-medium tracking-tight tabular-nums">{metric.value}</p>
                            <p class="font-jetbrains text-xs uppercase tracking-widest text-muted">{metric.label}</p>
                        </div>
                    ))}

                </div>
                </div>

        </div>
        <div class="mt-16">
            <p class="text-xs text-muted font-jetbrains uppercase tracking-widest">Eksperimen & latihan</p>
            <div class="mt-4 w-full grid sm:grid-cols-2 gap-4">
                {experiments.map((exp) => (
                    <a href={exp.link} class="w-full border border-line hover:border-accent transition-colors rounded-lg p-5 block">
                        <h3 class="text-2xl font-grotesk font-medium">{exp.title}</h3>
                        <p class="my-2 text-muted text-sm">{exp.description}</p>
                        <p class="text-muted text-xs font-jetbrains">{exp.techstack.join(" · ")}</p>
                    </a>
                ))}
            </div>
        </div>
    </div>
</div>